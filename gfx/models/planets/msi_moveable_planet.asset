entity = {
	name = "msi_movable_planet_ring_entity"
	pdxmesh = "orbital_ring_tier_03_mesh"
	attach = { "part1" = "aquatic_01_orbital_ring_section_entity" }
	attach = { "part2" = "aquatic_01_orbital_ring_section_entity" }
	attach = { "part3" = "aquatic_01_orbital_ring_section_entity" }
	attach = { "part4" = "aquatic_01_orbital_ring_section_entity" }
	attach = { "hub1" = "aquatic_01_orbital_ring_hub_tier_02_entity" }
	attach = { "hub2" = "aquatic_01_orbital_ring_hub_entity" }
	attach = { "hub3" = "aquatic_01_orbital_ring_hub_entity" }
	attach = { "hub4" = "aquatic_01_orbital_ring_hub_entity" }
	attach = { "rotate" = "orbital_ring_elevator_stage_3_entity" }
	default_state = "idle"
	state = { name = "idle" state_time = 5 animation = "idle"
		start_event = { trigger_once = yes sound = { soundeffect = "amb_megastructure_orbital_ring_03_idle" } }
	}
}



entity = {
	name = "msi_movable_planet_entity"
	pdxmesh = "planet_non_clouded_mesh"
	locator = { name = "root" position = { 0 0 0 } rotation = { 0 0 0 } }
	locator = { name = "ring" position = { 0 0 0 } rotation = { 0 0 0 } }
	attach = { "ring" = "msi_movable_planet_ring_entity" }

	#planet surface texture override
	meshsettings = {
		name = "planet_geosphereShape"
		texture_diffuse = "ai_01_diffuse.dds"
		texture_normal = "ai_01_normals.dds"
		texture_specular = "ai_01_specular.dds"
		shader = "PdxMeshTerra"
	}

	##pole texture override
	meshsettings = {
		name = "polesShape"
		texture_diffuse = "poles_barren_1_diffuse.dds"
		texture_normal = "poles_barren_1_normal.dds"
		texture_specular = "poles_barren_1_specular.dds"
	}

	default_state = "idle"
	state = {
		name = "idle"
		animation = "idle"
		time_offset = { 0 100 }
		start_event = {
			trigger_once = yes
			sound = { soundeffect = "amb_planet_world_machine" }
		}
	}

	attach = { planet = "city_planet_surface_ships_entity" }
}

